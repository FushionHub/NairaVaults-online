APP_NAME=NairaVault
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database - MySQL (Primary)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=naira_vault
DB_USERNAME=root
DB_PASSWORD=

# Database - PostgreSQL (Secondary Option)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=naira_vault
# DB_USERNAME=postgres
# DB_PASSWORD=

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Laravel Reverb (WebSockets)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@nairavault.com
MAIL_FROM_NAME="NairaVault"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/api/v1/auth/google/callback

# KYC - Dojah
DOJAH_APP_ID=
DOJAH_PRIVATE_KEY=
DOJAH_BASE_URL=https://api.dojah.io

# Crypto - Privy
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_BASE_URL=https://auth.privy.io

# Crypto - Binance
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_BASE_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443

# Crypto - CoinGecko
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Payments - Korapay
KORAPAY_SECRET_KEY=
KORAPAY_PUBLIC_KEY=
KORAPAY_ENCRYPTION_KEY=
KORAPAY_BASE_URL=https://api.korapay.com
KORAPAY_WEBHOOK_SECRET=

# Payments - Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_WEBHOOK_SECRET=

# Payments - Flutterwave
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_WEBHOOK_SECRET=

# Payments - PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Utilities - VTpass
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_SECRET_KEY=
VTPASS_BASE_URL=https://vtpass.com/api

# Gift Cards - Cardtonic
CARDTONIC_API_KEY=
CARDTONIC_BASE_URL=https://api.cardtonic.com

# AI - Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# AI - Grok (xAI)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1

# AI - ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# SMS/OTP - Termii
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com

# Analytics
GOOGLE_ANALYTICS_ID=

# Card Issuance
CARD_ISSUER=korapay
CARD_ISSUER_API_KEY=
CARD_ISSUER_BASE_URL=

# Push Notifications - Firebase
FIREBASE_SERVER_KEY=
FIREBASE_SENDER_ID=

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
